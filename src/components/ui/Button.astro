---
/* Composant bouton réutilisable */
export interface Props {
  variant?: 'primary' | 'ghost' | 'outline';
  href?: string;
  label: string;
  fullWidth?: boolean;
  type?: 'button' | 'submit' | 'reset';
}

const {
  variant = 'primary',
  href,
  label,
  fullWidth = false,
  type = 'button'
} = Astro.props;
---

{href ? (
  <a href={href} class:list={['btn', `btn--${variant}`, { 'btn--full': fullWidth }]}>
    {label}
  </a>
) : (
  <button type={type} class:list={['btn', `btn--${variant}`, { 'btn--full': fullWidth }]}>
    {label}
  </button>
)}

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1.75rem;
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    border-radius: var(--radius-sm);
    border: 1.5px solid transparent;
    cursor: pointer;
    transition: background-color 0.2s, color 0.2s, border-color 0.2s, transform 0.2s;
    text-decoration: none;
    white-space: nowrap;
  }

  .btn:hover {
    transform: translateY(-1px);
  }

  /* Variante primaire — or sur fond sable */
  .btn--primary {
    background-color: var(--gold-light);
    color: var(--navy);
    border-color: var(--gold-light);
  }
  .btn--primary:hover {
    background-color: var(--gold-mid);
    border-color: var(--gold-mid);
  }

  /* Variante ghost — transparent, texte blanc (usage fond sombre) */
  .btn--ghost {
    background-color: transparent;
    color: #fff;
    border-color: rgba(255,255,255,0.5);
  }
  .btn--ghost:hover {
    background-color: rgba(255,255,255,0.08);
    border-color: #fff;
  }

  /* Variante outline — bordure navy, texte navy */
  .btn--outline {
    background-color: transparent;
    color: var(--navy);
    border-color: var(--navy);
  }
  .btn--outline:hover {
    background-color: var(--navy);
    color: var(--sand);
  }

  .btn--full {
    width: 100%;
  }
</style>
