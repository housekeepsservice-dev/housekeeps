---
/* Section formules — fond navy, 3 colonnes dont 1 featured */
import Button from '../ui/Button.astro';
import SectionHeader from '../ui/SectionHeader.astro';

const alaCarteItems = [
  { label: 'Check-in voyageurs', price: '39€' },
  { label: 'Check-out voyageurs', price: '29€' },
  { label: 'Ménage & préparation', price: '75€' },
  { label: 'Gestion du linge', price: '15€' },
  { label: 'Intendance', price: '49€' },
];

const gestionItems = [
  'Gestion des réservations',
  'Communication voyageurs',
  'Tarification dynamique',
  'Coordination ménage & linge',
  'Check-in / Check-out',
  'Assistance voyageurs 7j/7',
  'Compte-rendu & photos',
];

const residenceItems = [
  'Visite mensuelle complète',
  'Aération & contrôle général',
  'Vérification extérieure',
  'Relevé des compteurs',
  'Photos envoyées au propriétaire',
  'Alerte immédiate anomalie',
];

const checkIcon = `<svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
  <path d="M3 8l3.5 3.5L13 4.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
</svg>`;
---

<section class="formules" id="formules" aria-labelledby="formules-title">
  <div class="container">
    <SectionHeader
      label="Nos offres"
      title="Choisissez votre formule"
      centered={true}
      light={true}
    />

    <div class="formules__grid">

      <!-- Carte À la carte -->
      <article class="formules__card formules__card--dark">
        <header class="formules__card-header">
          <h3 class="formules__card-title">À la carte</h3>
          <p class="formules__card-subtitle">Payez uniquement ce dont vous avez besoin.</p>
        </header>
        <ul class="formules__carte-list">
          {alaCarteItems.map(item => (
            <li class="formules__carte-item">
              <span class="formules__carte-label">{item.label}</span>
              <span class="formules__carte-price">à partir de <strong>{item.price}</strong></span>
            </li>
          ))}
        </ul>
        <div class="formules__card-cta">
          <Button href="/contact" label="Demander un devis" variant="ghost" fullWidth={true} />
        </div>
      </article>

      <!-- Carte Gestion complète — FEATURED -->
      <article class="formules__card formules__card--featured" aria-label="Formule recommandée">
        <div class="formules__badge">Recommandé</div>
        <header class="formules__card-header">
          <h3 class="formules__card-title formules__card-title--dark">Gestion complète</h3>
          <div class="formules__price">
            <span class="formules__price-value">20%</span>
            <span class="formules__price-label">des revenus générés</span>
          </div>
        </header>
        <ul class="formules__features">
          {gestionItems.map(item => (
            <li class="formules__feature formules__feature--dark">
              <span class="formules__check formules__check--dark" set:html={checkIcon} />
              {item}
            </li>
          ))}
        </ul>
        <div class="formules__card-cta">
          <Button href="/contact" label="Choisir ce forfait" variant="outline" fullWidth={true} />
        </div>
      </article>

      <!-- Carte Résidence secondaire -->
      <article class="formules__card formules__card--dark">
        <header class="formules__card-header">
          <h3 class="formules__card-title">Résidence secondaire</h3>
          <div class="formules__price">
            <span class="formules__price-value formules__price-value--light">79€</span>
            <span class="formules__price-label formules__price-label--light">/mois</span>
          </div>
        </header>
        <ul class="formules__features">
          {residenceItems.map(item => (
            <li class="formules__feature">
              <span class="formules__check" set:html={checkIcon} />
              {item}
            </li>
          ))}
        </ul>
        <div class="formules__card-cta">
          <Button href="/contact" label="Nous contacter" variant="ghost" fullWidth={true} />
        </div>
      </article>

    </div>
  </div>
</section>

<style>
  .formules {
    background-color: var(--navy);
    padding: var(--section-pad);
  }

  .formules__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    align-items: start;
  }

  @media (min-width: 900px) {
    .formules__grid {
      grid-template-columns: repeat(3, 1fr);
      align-items: stretch;
    }
  }

  /* Carte de base — fond navy sombre */
  .formules__card {
    position: relative;
    border-radius: var(--radius-md);
    padding: 2rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .formules__card--dark {
    background-color: var(--navy-mid);
    border: 1px solid rgba(255,255,255,0.08);
  }

  /* Carte featured — fond or mid */
  .formules__card--featured {
    background-color: var(--gold-mid);
    border: 1px solid var(--gold);
    transform: none;
  }

  @media (min-width: 900px) {
    .formules__card--featured {
      transform: translateY(-0.75rem);
    }
  }

  /* Badge recommandé */
  .formules__badge {
    position: absolute;
    top: -0.75rem;
    left: 50%;
    transform: translateX(-50%);
    background-color: var(--navy);
    color: var(--gold-light);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.3rem 1rem;
    border-radius: 999px;
    white-space: nowrap;
    border: 1px solid var(--gold-mid);
  }

  .formules__card-header {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .formules__card-title {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    font-weight: 400;
    color: #fff;
  }

  .formules__card-title--dark {
    color: var(--navy);
  }

  .formules__card-subtitle {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.5);
    line-height: 1.5;
  }

  /* Prix */
  .formules__price {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
  }

  .formules__price-value {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 400;
    color: var(--gold-light);
    line-height: 1;
  }

  .formules__price-value--light {
    color: var(--gold-light);
  }

  .formules__price-label {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.5);
  }

  .formules__price-label--light {
    color: rgba(255,255,255,0.5);
  }

  /* Featured : couleurs sur fond or */
  .formules__card--featured .formules__price-value {
    color: var(--navy);
  }

  .formules__card--featured .formules__price-label {
    color: var(--navy-light);
  }

  /* Listes features */
  .formules__features {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    flex: 1;
  }

  .formules__feature {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-size: 0.875rem;
    color: rgba(255,255,255,0.7);
    line-height: 1.5;
  }

  .formules__feature--dark {
    color: var(--navy);
  }

  .formules__check {
    flex-shrink: 0;
    margin-top: 0.1rem;
    color: var(--gold-light);
  }

  .formules__check--dark {
    color: var(--navy);
  }

  /* Liste à la carte */
  .formules__carte-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    flex: 1;
  }

  .formules__carte-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.65rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    font-size: 0.875rem;
  }

  .formules__carte-label {
    color: rgba(255,255,255,0.7);
  }

  .formules__carte-price {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.45);
    white-space: nowrap;
  }

  .formules__carte-price strong {
    color: var(--gold-light);
    font-weight: 500;
  }

  .formules__card-cta {
    margin-top: auto;
  }
</style>
