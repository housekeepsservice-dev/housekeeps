---
/* Section héros — fond navy plein écran */
import Button from '../ui/Button.astro';
---

<section class="hero" aria-label="Section héros">
  <div class="hero__inner container">
    <div class="hero__content">
      <span class="hero__eyebrow animate-fade-up">Conciergerie locale</span>
      <h1 class="hero__title animate-fade-up-delay-1">
        Les gardiennes<br />
        de vos <em>maisons</em>
      </h1>
      <p class="hero__subtitle animate-fade-up-delay-2">
        Vous profitez de la côte, nous veillons sur le reste.
      </p>
      <div class="hero__actions animate-fade-up-delay-3">
        <Button href="/services" label="Découvrir nos services" variant="primary" />
        <Button href="/contact" label="Nous contacter" variant="ghost" />
      </div>
    </div>
  </div>

  <!-- Zones géographiques -->
  <div class="hero__zones">
    <span class="hero__zones-label">Bordeaux</span>
    <span class="hero__zones-sep" aria-hidden="true">·</span>
    <span class="hero__zones-label">Bassin d'Arcachon</span>
    <span class="hero__zones-sep" aria-hidden="true">·</span>
    <span class="hero__zones-label">Lacanau</span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    background-color: var(--navy);
    min-height: 92vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
  }

  /* Motif décoratif subtil en arrière-plan */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 60% 40%, rgba(117,90,34,0.12) 0%, transparent 70%),
      radial-gradient(ellipse 50% 40% at 10% 80%, rgba(254,216,147,0.06) 0%, transparent 60%);
    pointer-events: none;
  }

  .hero__inner {
    flex: 1;
    display: flex;
    align-items: center;
    padding-top: 6rem;
    padding-bottom: 4rem;
  }

  .hero__content {
    max-width: 52ch;
  }

  /* Eyebrow — label doré */
  .hero__eyebrow {
    display: block;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold-light);
    margin-bottom: 1.25rem;
  }

  /* Titre principal */
  .hero__title {
    font-family: var(--font-heading);
    font-size: clamp(2.8rem, 6vw, 4.5rem);
    font-weight: 400;
    line-height: 1.1;
    color: #fff;
    margin-bottom: 1.5rem;
  }

  /* "maisons" en italique doré */
  .hero__title em {
    font-style: italic;
    color: var(--gold-light);
  }

  .hero__subtitle {
    font-size: clamp(1rem, 1.5vw, 1.15rem);
    color: rgba(255,255,255,0.65);
    margin-bottom: 2.5rem;
    line-height: 1.6;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
  }

  /* Zones géographiques en bas */
  .hero__zones {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.75rem 1rem;
    padding: 1.25rem 2rem;
    border-top: 1px solid rgba(255,255,255,0.08);
    background-color: rgba(255,255,255,0.03);
  }

  .hero__zones-label {
    font-size: 0.8rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
  }

  .hero__zones-sep {
    color: var(--gold-light);
    opacity: 0.5;
    font-size: 0.9rem;
  }
</style>
