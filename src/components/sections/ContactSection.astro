---
/* Section contact — fond sand, 2 colonnes */
import Button from '../ui/Button.astro';
import SectionHeader from '../ui/SectionHeader.astro';
---

<section class="contact-section" id="contact" aria-labelledby="contact-title">
  <div class="container">
    <div class="contact-section__grid">

      <!-- Colonne info -->
      <div class="contact-section__info">
        <SectionHeader
          label="Parlons de votre bien"
          title="Contactez-nous"
        />
        <p class="contact-section__intro">
          Réponse garantie sous 24h. Échangeons pour découvrir comment
          House Keeps peut maximiser vos revenus locatifs.
        </p>

        <div class="contact-section__details">
          <a href="tel:+33660990758" class="contact-section__detail">
            <span class="contact-section__detail-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                <path d="M5 2h4l1.5 4-2.5 1.5a10 10 0 0 0 4.5 4.5L14 9.5l4 1.5v4a2 2 0 0 1-2 2C7.16 17 3 12.84 3 4a2 2 0 0 1 2-2z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/>
              </svg>
            </span>
            <div>
              <span class="contact-section__detail-label">Téléphone</span>
              <span class="contact-section__detail-value">+33 6 60 99 07 58</span>
            </div>
          </a>

          <a href="mailto:housekeeps.service@gmail.com" class="contact-section__detail">
            <span class="contact-section__detail-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                <rect x="2" y="4" width="16" height="12" rx="2" stroke="currentColor" stroke-width="1.3"/>
                <path d="M2 7l8 5 8-5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
              </svg>
            </span>
            <div>
              <span class="contact-section__detail-label">Email</span>
              <span class="contact-section__detail-value">housekeeps.service@gmail.com</span>
            </div>
          </a>
        </div>
      </div>

      <!-- Colonne formulaire -->
      <div class="contact-section__form-wrap">
        <form
          class="contact-form"
          name="contact"
          method="POST"
          action="https://formspree.io/f/meedwoda"
          aria-label="Formulaire de contact"
        >
          <!-- Prénom + Nom -->
          <div class="contact-form__row">
            <div class="contact-form__field">
              <label for="prenom" class="contact-form__label">Prénom <span aria-hidden="true">*</span></label>
              <input
                type="text"
                id="prenom"
                name="prenom"
                class="contact-form__input"
                required
                autocomplete="given-name"
                placeholder="Marie"
              />
            </div>
            <div class="contact-form__field">
              <label for="nom" class="contact-form__label">Nom <span aria-hidden="true">*</span></label>
              <input
                type="text"
                id="nom"
                name="nom"
                class="contact-form__input"
                required
                autocomplete="family-name"
                placeholder="Dupont"
              />
            </div>
          </div>

          <!-- Email -->
          <div class="contact-form__field">
            <label for="email" class="contact-form__label">Email <span aria-hidden="true">*</span></label>
            <input
              type="email"
              id="email"
              name="email"
              class="contact-form__input"
              required
              autocomplete="email"
              placeholder="marie@exemple.fr"
            />
          </div>

          <!-- Téléphone -->
          <div class="contact-form__field">
            <label for="telephone" class="contact-form__label">Téléphone <span aria-hidden="true">*</span></label>
            <input
              type="tel"
              id="telephone"
              name="telephone"
              class="contact-form__input"
              required
              autocomplete="tel"
              placeholder="+33 6 12 34 56 78"
            />
          </div>

          <!-- Adresse du bien -->
          <div class="contact-form__field">
            <label for="adresse" class="contact-form__label">
              Adresse du bien
              <span class="contact-form__optional">(optionnel)</span>
            </label>
            <input
              type="text"
              id="adresse"
              name="adresse"
              class="contact-form__input"
              placeholder="12 rue des Dunes, Arcachon"
            />
          </div>

          <!-- Message -->
          <div class="contact-form__field">
            <label for="message" class="contact-form__label">Message <span aria-hidden="true">*</span></label>
            <textarea
              id="message"
              name="message"
              class="contact-form__textarea"
              rows="4"
              required
              placeholder="Décrivez votre bien et vos besoins..."
            ></textarea>
          </div>

          <!-- RGPD -->
          <div class="contact-form__field contact-form__field--check">
            <input
              type="checkbox"
              id="rgpd"
              name="rgpd"
              class="contact-form__checkbox"
              required
            />
            <label for="rgpd" class="contact-form__check-label">
              J'accepte que mes données soient utilisées pour traiter ma demande.
              <a href="/mentions-legales" class="contact-form__link">En savoir plus</a>
            </label>
          </div>

          <!-- Bouton envoi -->
          <Button
            type="submit"
            label="Envoyer ma demande"
            variant="primary"
            fullWidth={true}
          />
        </form>
      </div>

    </div>
  </div>
</section>

<style>
  .contact-section {
    background-color: var(--sand);
    padding: var(--section-pad);
  }

  .contact-section__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 900px) {
    .contact-section__grid {
      grid-template-columns: 1fr 1.2fr;
      align-items: start;
    }
  }

  .contact-section__intro {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 40ch;
  }

  /* Détails de contact */
  .contact-section__details {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact-section__detail {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    transition: opacity 0.2s;
  }

  .contact-section__detail:hover {
    opacity: 0.75;
  }

  .contact-section__detail-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border: 1px solid var(--outline-subtle);
    border-radius: var(--radius-sm);
    color: var(--gold);
    flex-shrink: 0;
  }

  .contact-section__detail-label {
    display: block;
    font-size: 0.75rem;
    color: var(--text-muted);
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 0.2rem;
  }

  .contact-section__detail-value {
    display: block;
    font-size: 0.9rem;
    color: var(--navy);
    font-weight: 500;
  }

  /* Formulaire */
  .contact-section__form-wrap {
    background-color: #fff;
    border: 1px solid var(--outline-subtle);
    border-radius: var(--radius-md);
    padding: 2rem;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact-form__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .contact-form__field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .contact-form__label {
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--navy);
    letter-spacing: 0.02em;
  }

  .contact-form__optional {
    font-weight: 400;
    color: var(--text-muted);
    font-size: 0.78rem;
    margin-left: 0.25rem;
  }

  .contact-form__input,
  .contact-form__textarea {
    padding: 0.65rem 0.85rem;
    border: 1px solid var(--sand-dark);
    border-radius: var(--radius-sm);
    background-color: var(--sand);
    color: var(--text);
    font-size: 0.9rem;
    transition: border-color 0.2s, box-shadow 0.2s;
    width: 100%;
    resize: vertical;
  }

  .contact-form__input::placeholder,
  .contact-form__textarea::placeholder {
    color: var(--outline);
  }

  .contact-form__input:focus,
  .contact-form__textarea:focus {
    outline: none;
    border-color: var(--gold-mid);
    box-shadow: 0 0 0 3px rgba(230,194,127,0.15);
  }

  .contact-form__textarea {
    min-height: 110px;
  }

  /* Checkbox RGPD */
  .contact-form__field--check {
    flex-direction: row;
    align-items: flex-start;
    gap: 0.65rem;
  }

  .contact-form__checkbox {
    width: 1rem;
    height: 1rem;
    margin-top: 0.1rem;
    flex-shrink: 0;
    accent-color: var(--navy);
    cursor: pointer;
  }

  .contact-form__check-label {
    font-size: 0.8rem;
    color: var(--text-muted);
    line-height: 1.5;
    cursor: pointer;
  }

  .contact-form__link {
    color: var(--gold);
    text-decoration: underline;
    text-decoration-color: transparent;
    transition: text-decoration-color 0.2s;
  }

  .contact-form__link:hover {
    text-decoration-color: var(--gold);
  }
</style>
