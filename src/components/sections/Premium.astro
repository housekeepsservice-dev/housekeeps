---
/* Section offre premium — fond navy-mid, 2 colonnes */
import SectionHeader from '../ui/SectionHeader.astro';

const features = [
  {
    title: 'Intendance renforcée',
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
      <path d="M10 2l6.5 2.5v5c0 4-2.5 6.5-6.5 8-4-1.5-6.5-4-6.5-8v-5L10 2z" stroke="currentColor" stroke-width="1.3"/>
    </svg>`,
  },
  {
    title: 'Services VIP',
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
      <path d="M10 2l2 5.5H18l-4.8 3.5 1.8 5.5L10 13l-5 3.5 1.8-5.5L2 7.5h6z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/>
    </svg>`,
  },
  {
    title: 'Suivi travaux',
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
      <rect x="2" y="2" width="16" height="16" rx="2" stroke="currentColor" stroke-width="1.3"/>
      <line x1="6" y1="7" x2="14" y2="7" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
      <line x1="6" y1="10" x2="14" y2="10" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
      <line x1="6" y1="13" x2="10" y2="13" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
    </svg>`,
  },
  {
    title: 'Préparation séjour',
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
      <path d="M3 10L10 4l7 6" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M5 8.5V17h4v-4h2v4h4V8.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>`,
  },
];
---

<section class="premium" aria-labelledby="premium-title">
  <div class="container">
    <div class="premium__grid">

      <!-- Colonne texte -->
      <div class="premium__text">
        <SectionHeader
          label="Offre sur-mesure"
          title="Premium pour les villas d'exception"
          light={true}
        />
        <p class="premium__desc">
          Parce que chaque demeure d'exception est unique, nous proposons un
          accompagnement haute couture avec intendance renforcée, services
          personnalisés et préparation avant séjour.
        </p>

        <ul class="premium__features">
          {features.map(f => (
            <li class="premium__feature">
              <span class="premium__feature-icon" set:html={f.icon} />
              <span class="premium__feature-label">{f.title}</span>
            </li>
          ))}
        </ul>

        <a href="/contact" class="premium__cta">
          Devenir partenaire
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

      <!-- Colonne visuel placeholder -->
      <div class="premium__visual" aria-hidden="true">
        <div class="premium__photos">
          <div class="premium__photo premium__photo--large">
            <span>Photo villa</span>
          </div>
          <div class="premium__photo">
            <span>Intérieur</span>
          </div>
          <div class="premium__photo">
            <span>Vue mer</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .premium {
    background-color: var(--navy-mid);
    padding: var(--section-pad);
  }

  .premium__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 900px) {
    .premium__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .premium__desc {
    color: rgba(255,255,255,0.6);
    font-size: 0.95rem;
    line-height: 1.75;
    margin-bottom: 2rem;
    max-width: 46ch;
  }

  /* Fonctionnalités */
  .premium__features {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  .premium__feature {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .premium__feature-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border: 1px solid rgba(254,216,147,0.25);
    border-radius: var(--radius-sm);
    color: var(--gold-light);
    flex-shrink: 0;
  }

  .premium__feature-label {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.75);
  }

  /* CTA lien fleché */
  .premium__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--gold-light);
    border-bottom: 1px solid rgba(254,216,147,0.3);
    padding-bottom: 0.2rem;
    transition: border-color 0.2s, gap 0.2s;
  }

  .premium__cta:hover {
    border-color: var(--gold-light);
    gap: 0.75rem;
  }

  /* Grille photos placeholders */
  .premium__photos {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
    gap: 0.75rem;
  }

  .premium__photo {
    background-color: var(--sand-dark);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 160px;
    font-style: italic;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  /* Première photo prend toute la largeur */
  .premium__photo--large {
    grid-column: 1 / -1;
    min-height: 220px;
  }
</style>
