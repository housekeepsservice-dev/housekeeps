---
/* Page d'accueil — assemble toutes les sections */
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Hero from '../components/sections/Hero.astro';
import Values from '../components/sections/Values.astro';
import Services from '../components/sections/Services.astro';
import Stats from '../components/sections/Stats.astro';
import Formules from '../components/sections/Formules.astro';
import HowItWorks from '../components/sections/HowItWorks.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import Premium from '../components/sections/Premium.astro';
import ContactSection from '../components/sections/ContactSection.astro';
---

<BaseLayout
  title="House Keeps — Conciergerie RBNB Côte Atlantique"
  description="Gestion de vos locations saisonnières à Bordeaux, Bassin d'Arcachon et Lacanau. Sérénité garantie."
>
  <Header />
  <main id="main-content">
    <Hero />
    <Values />
    <Services />
    <Stats />
    <Formules />
    <HowItWorks />
    <Testimonials />
    <Premium />
    <ContactSection />
  </main>
  <Footer />
</BaseLayout>
